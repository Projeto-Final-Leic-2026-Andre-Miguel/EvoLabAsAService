@baseUrl = http://localhost:8080
@localUserName = request-http-user
@localUserEmail = request-http-user@evolab.dev
@localUserPassword = 12345
@oauthUserName = request-http-oauth
@oauthUserEmail = request-http-oauth@evolab.dev
@oauthProvider = GOOGLE
@oauthProviderId = google-sub-request-http
@projectName = EvoLab HTTP Demo
@projectDescription = Projeto criado pelo Requests.http
@updatedProjectName = EvoLab HTTP Demo Updated
@updatedProjectDescription = Projeto atualizado pelo Requests.http
@initialProgram = def solve
@updatedInitialProgram = def solv
@evaluatorCode = def evaluate
@updatedEvaluatorCode = def evaluate
@projectStatus = QUEUED
@llmProvider = OPENAI
@llmApiKey = sk-your-real-openai-key
@updatedLlmApiKey = sk-your-real-openai-key-updated
@modelName = gpt-4o-mini
@updatedModelName = gpt-4.1-mini
@maxIter = 20
@updatedMaxIter = 30
@checkpointInterval = 5
@updatedCheckpointInterval = 10
@jobId = 1


### UserController - Create local user
POST {{baseUrl}}/api/users/local
Content-Type: application/json

{
  "name": "{{localUserName}}",
  "email": "{{localUserEmail}}",
  "password": "{{localUserPassword}}"
}

### UserController - Create OAuth user
POST {{baseUrl}}/api/users/oauth
Content-Type: application/json

{
  "name": "{{oauthUserName}}",
  "email": "{{oauthUserEmail}}",
  "provider": "{{oauthProvider}}",
  "providerId": "{{oauthProviderId}}"
}

### UserController - Create token
POST {{baseUrl}}/api/users/token
Content-Type: application/json

{
  "email": "{{localUserEmail}}",
  "password": "{{localUserPassword}}"
}

### UserController - Get authenticated user
GET {{baseUrl}}/api/me
Authorization: Bearer {{token}}

### UserController - Get all users
GET {{baseUrl}}/api/users

### ProjectController - Create project
POST {{baseUrl}}/api/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "{{projectName}}",
  "description": "{{projectDescription}}",
  "initialProgram": "{{initialProgram}}",
  "evaluatorCode": "{{evaluatorCode}}"
}

### ProjectController - Get authenticated user's projects
GET {{baseUrl}}/api/projects/me
Authorization: Bearer {{token}}

### ProjectController - Get all projects
GET {{baseUrl}}/api/projects

### ProjectController - Get project by id
GET {{baseUrl}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}

### LLMCredentialsController - Create LLM credential
POST {{baseUrl}}/api/llm-credentials
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "llm": "{{llmProvider}}",
  "apiKey": "{{llmApiKey}}"
}

### LLMCredentialsController - Get LLM credential by id
GET {{baseUrl}}/api/llm-credentials/{{llmCredentialId}}
Authorization: Bearer {{token}}

### ConfigController - Create config
POST {{baseUrl}}/api/configs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "projectId": {{projectId}},
  "llmCredentialsId": {{llmCredentialId}},
  "modelName": "{{modelName}}",
  "maxIter": {{maxIter}},
  "checkPointInterval": {{checkpointInterval}},
  "additionalParams": {
    "llm.api_key": "${OPENAI_API_KEY}",
    "database.feature_dimensions": "complexity,diversity",
    "prompt.num_top_programs": "3"
  }
}

### ConfigController - Get config by id
GET {{baseUrl}}/api/configs/{{configId}}
Authorization: Bearer {{token}}

### ConfigController - Get authenticated user's configs
GET {{baseUrl}}/api/configs/me
Authorization: Bearer {{token}}

### ConfigController - Generate temporary config file
POST {{baseUrl}}/api/configs/{{configId}}/temporary-file
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "projectId": {{projectId}},
  "jobId": {{jobId}}
}

### ConfigController - Update config
PUT {{baseUrl}}/api/configs/{{configId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "modelName": "{{updatedModelName}}",
  "maxIter": {{updatedMaxIter}},
  "checkPointInterval": {{updatedCheckpointInterval}},
  "additionalParams": {
    "llm.api_key": "${OPENAI_API_KEY}",
    "database.feature_dimensions": "complexity,diversity",
    "prompt.num_top_programs": "4",
    "evaluator.parallel_evaluations": "2"
  }
}

### ProjectController - Update project details
PUT {{baseUrl}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "{{updatedProjectName}}",
  "description": "{{updatedProjectDescription}}",
  "configId": {{configId}},
  "initialProgram": "{{updatedInitialProgram}}",
  "evaluatorCode": "{{updatedEvaluatorCode}}"
}

### ProjectController - Update project status
PUT {{baseUrl}}/api/projects/{{projectId}}/status
Content-Type: application/json

{
  "status": "{{projectStatus}}"
}

### LLMCredentialsController - Update LLM credential
PUT {{baseUrl}}/api/llm-credentials/{{llmCredentialId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "llm": "{{llmProvider}}",
  "apiKey": "{{updatedLlmApiKey}}"
}

### ConfigController - Delete config
DELETE {{baseUrl}}/api/configs/{{configId}}
Authorization: Bearer {{token}}

### LLMCredentialsController - Delete LLM credential
DELETE {{baseUrl}}/api/llm-credentials/{{llmCredentialId}}
Authorization: Bearer {{token}}

### ProjectController - Delete project
DELETE {{baseUrl}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}

### UserController - Logout
POST {{baseUrl}}/api/logout
Authorization: Bearer {{token}}

### UserController - Delete local user by id
DELETE {{baseUrl}}/api/users/{{createdUserId}}

### UserController - Delete OAuth user by id
DELETE {{baseUrl}}/api/users/{{createdOAuthUserId}}
