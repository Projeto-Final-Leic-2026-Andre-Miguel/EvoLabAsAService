@baseUrl = http://localhost:8080
@token =PY-aayGcDphotce_xbOI_jIvX4LvF8epyHotG1NDOiM=
@userIdToDelete = 4
@localEmail = Teste1@evolab.dev
@localPassword = 12345
@nome = Teste
@llmCredentialId = 1
@configId = 4
@projectId = 6
@jobId = 4

### Criar utilizador local
POST {{baseUrl}}/api/users/local
Content-Type: application/json

{
  "name": "user-local-1",
  "email": "{{localEmail}}",
  "password": "{{localPassword}}"
}

### Criar utilizador OAuth (GOOGLE)
POST {{baseUrl}}/api/users/oauth
Content-Type: application/json

{
  "name": "user-oauth-1",
  "email": "user-oauth-1@example.com",
  "provider": "GOOGLE",
  "providerId": "google-sub-123"
}

### Obter token (login local)
POST {{baseUrl}}/api/users/token
Content-Type: application/json

{
  "email": "{{localEmail}}",
  "password": "{{localPassword}}"
}

### Obter utilizador autenticado
GET {{baseUrl}}/api/me
Authorization: Bearer {{token}}

### Logout
POST {{baseUrl}}/api/logout
Authorization: Bearer {{token}}

### Listar todos os users
GET {{baseUrl}}/api/users

### Apagar user por id
DELETE {{baseUrl}}/api/users/{{userIdToDelete}}
Authorization: Bearer {{token}}


### [Opcional] Verificar credencial LLM antes de criar Config
GET {{baseUrl}}/api/llm-credentials/{{llmCredentialId}}
Authorization: Bearer {{token}}

### Criar config
POST {{baseUrl}}/api/configs
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "projectId": {{projectId}},
  "llmCredentialsId": {{llmCredentialId}},
  "modelName": "gpt-4o-mini",
  "maxIter": 20,
  "checkPointInterval": 5,
  "additionalParams": {
    "temperature": "0.7",
    "topP": "1.0"
  }
}

### Obter config por id
GET {{baseUrl}}/api/configs/{{configId}}
Authorization: Bearer {{token}}

### Gerar ficheiro temporario para runtime config
POST {{baseUrl}}/api/configs/{{configId}}/temporary-file
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "projectId": {{projectId}}
}

### Listar configs do utilizador autenticado
GET {{baseUrl}}/api/configs/me
Authorization: Bearer {{token}}

### Atualizar config
PUT {{baseUrl}}/api/configs/{{configId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "modelName": "gpt-4.1-mini",
  "maxIter": 30,
  "checkPointInterval": 10,
  "additionalParams": {
    "temperature": "0.5",
    "topP": "0.9"
  }
}

### Apagar config
DELETE {{baseUrl}}/api/configs/{{configId}}
Authorization: Bearer {{token}}

### Criar projeto
POST {{baseUrl}}/api/projects
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Projeto Demo",
  "description": "Projeto de teste para o modulo Project",
  "initialProgram": "def solve(x): return x",
  "evaluatorCode": "def evaluate(candidate): return 1.0"
}

### Obter projeto por id
GET {{baseUrl}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}

### Listar projetos do utilizador autenticado
GET {{baseUrl}}/api/projects/me
Authorization: Bearer {{token}}

### Listar todos os projetos
GET {{baseUrl}}/api/projects

### Atualizar detalhes do projeto
PUT {{baseUrl}}/api/projects/{{projectId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Projeto Demo Atualizado",
  "description": "Descricao atualizada do projeto",
  "configId": {{configId}},
  "initialProgram": "def solve(x): return x * 2",
  "evaluatorCode": "def evaluate(candidate): return 2.0"
}

### Atualizar estado do projeto
PUT {{baseUrl}}/api/projects/{{projectId}}/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "QUEUED"
}

### Apagar projeto
DELETE {{baseUrl}}/api/projects/{{projectId}}
Authorization: Bearer {{token}}

